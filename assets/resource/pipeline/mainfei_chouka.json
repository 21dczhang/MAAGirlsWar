    "MianFeiChouKa_MianFeiChouKa_Find_MianFeiChouKa_And_Click": {
        "recognition": "DirectHit",
        "action": "Custom",
        "custom_action": "TraverseAndClick",
        "custom_action_param": {
            // ── 识别方式 ──────────────────────────────────────
            // "method": "template" | "ocr"
            "method": "template",
            // [template] 待匹配的模板图片文件名（resource 目录下的路径）
            "template": "免费券红点.png",
            "roi": [
                8,
                83,
                148,
                628
            ],
            // [ocr] 待匹配的文字列表，命中其中任意一项即算匹配
            // "ocr_text": ["词A", "词B"],
            // 匹配分数阈值（0~1），高于此值才纳入遍历
            "threshold": 0.7,
            // ── 终止条件 ──────────────────────────────────────
            // "stop_method": "template" | "ocr"
            "stop_method": "ocr",
            // [template] 终止条件：识别到该图片则停止
            // "stop_template": "ui/end_screen.png",
            // [ocr] 终止条件：OCR 识别到包含以下任一字符串则停止
            "stop_ocr_text": [
                "屋",
            ],
            "stop_roi": [
                8,
                83,
                148,
                628
            ],
            // ── 任务配置 ──────────────────────────────────────
            // 点击每个匹配项后执行的任务节点名
            "task_each": "MianFeiChouKa_MianFeiChouKa_Select_Type_Start",
            // 每轮遍历全部结束后执行的任务节点名
            "task_after_round": "MianFeiChouKa_MianFeiChouKa_Swip_Once",
            // ── 可选配置 ──────────────────────────────────────
            // 两次识别之间的等待时间（秒），默认 0.5
            "round_delay": 0.5,
            // 每次点击后、执行 task_each 前的等待时间（秒），默认 0.3
            "click_delay": 0.3,
            // 最大循环轮数，防止死循环，默认 50，设为 -1 表示不限制
            "max_rounds": 10
        },
        "max_hit": 1,
        "focus": "【日志】点击处理（MianFeiChouKa_MianFeiChouKa_Find_MianFeiChouKa_And_Click）"
    },
